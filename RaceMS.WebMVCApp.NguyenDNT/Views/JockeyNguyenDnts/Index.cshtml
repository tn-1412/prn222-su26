@model IEnumerable<RaceMS.Entities.NguyenDNT.Models.JockeyNguyenDnt>

@{
    ViewData["Title"] = "Danh sách Jockey";
    int activeCount = Model.Count(j => j.IsActive);
    int totalCount  = Model.Count();
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@@600;700&family=Inter:wght@@400;500;600&display=swap');

    .jl-wrapper {
        max-width: 1100px;
        margin: 2rem auto;
        font-family: 'Inter', sans-serif;
    }

    /* ── HEADER ── */
    .jl-header {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
        border-radius: 16px 16px 0 0;
        padding: 2rem 2.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        position: relative;
        overflow: hidden;
    }

    .jl-header::before {
        content: '';
        position: absolute;
        top: -50px; right: -50px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(139,92,246,.12);
    }

    .jl-header-left h1 {
        font-family: 'Playfair Display', serif;
        color: #fff;
        font-size: 1.8rem;
        font-weight: 700;
        margin: 0 0 .25rem;
    }

    .jl-header-left p {
        color: #94a3b8;
        font-size: .875rem;
        margin: 0;
    }

    .jl-header-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(139,92,246,.2);
        border: 1px solid rgba(139,92,246,.4);
        color: #c4b5fd;
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        padding: 3px 10px;
        border-radius: 20px;
        margin-bottom: .6rem;
    }

    .btn-add {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: linear-gradient(135deg, #7c3aed, #6d28d9);
        color: #fff;
        font-size: .875rem;
        font-weight: 600;
        padding: 10px 22px;
        border-radius: 10px;
        border: none;
        text-decoration: none;
        white-space: nowrap;
        box-shadow: 0 4px 14px rgba(109,40,217,.4);
        transition: all .2s;
        position: relative;
        z-index: 1;
    }

    .btn-add:hover {
        background: linear-gradient(135deg, #6d28d9, #5b21b6);
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(109,40,217,.5);
        text-decoration: none;
    }

    /* ── STATS BAR ── */
    .jl-stats {
        display: flex;
        gap: 1px;
        background: #e9d5ff;
    }

    .jl-stat {
        flex: 1;
        background: #faf5ff;
        padding: .9rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .jl-stat-icon {
        font-size: 1.4rem;
        line-height: 1;
    }

    .jl-stat-info .value {
        font-size: 1.3rem;
        font-weight: 700;
        color: #1e1b4b;
        line-height: 1.1;
    }

    .jl-stat-info .label {
        font-size: .72rem;
        color: #7c3aed;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    /* ── SEARCH BAR ── */
    .jl-toolbar {
        background: #fff;
        border-left: 1px solid #e2e8f0;
        border-right: 1px solid #e2e8f0;
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .search-box {
        position: relative;
        flex: 1;
        min-width: 200px;
    }

    .search-box input {
        width: 100%;
        padding: 8px 14px 8px 38px;
        border: 1.5px solid #d1d5db;
        border-radius: 8px;
        font-size: .875rem;
        font-family: 'Inter', sans-serif;
        color: #111827;
        background: #f9fafb;
        transition: border-color .2s, box-shadow .2s;
        box-sizing: border-box;
    }

    .search-box input:focus {
        outline: none;
        border-color: #8b5cf6;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(139,92,246,.1);
    }

    .search-box .search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
        font-size: .9rem;
        pointer-events: none;
    }

    .filter-select {
        padding: 8px 12px;
        border: 1.5px solid #d1d5db;
        border-radius: 8px;
        font-size: .875rem;
        font-family: 'Inter', sans-serif;
        color: #374151;
        background: #f9fafb;
        cursor: pointer;
    }

    .filter-select:focus {
        outline: none;
        border-color: #8b5cf6;
        box-shadow: 0 0 0 3px rgba(139,92,246,.1);
    }

    /* ── TABLE ── */
    .jl-table-wrap {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-top: none;
        border-radius: 0 0 16px 16px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0,0,0,.07);
    }

    .jl-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .875rem;
    }

    .jl-table thead {
        background: #f8fafc;
        border-bottom: 2px solid #e9d5ff;
    }

    .jl-table thead th {
        padding: 12px 16px;
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: #6b21a8;
        white-space: nowrap;
    }

    .jl-table thead th:first-child { padding-left: 1.5rem; }
    .jl-table thead th:last-child  { padding-right: 1.5rem; text-align: center; }

    .jl-table tbody tr {
        border-bottom: 1px solid #f1f5f9;
        transition: background .15s;
    }

    .jl-table tbody tr:last-child { border-bottom: none; }
    .jl-table tbody tr:hover { background: #faf5ff; }

    .jl-table tbody td {
        padding: 13px 16px;
        color: #374151;
        vertical-align: middle;
    }

    .jl-table tbody td:first-child { padding-left: 1.5rem; }
    .jl-table tbody td:last-child  { padding-right: 1.5rem; }

    /* row number */
    .row-num {
        font-size: .72rem;
        font-weight: 700;
        color: #a78bfa;
        background: #f5f3ff;
        border-radius: 6px;
        padding: 2px 8px;
        display: inline-block;
    }

    /* name cell */
    .jockey-name {
        font-weight: 600;
        color: #1e1b4b;
    }

    .jockey-avatar {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: linear-gradient(135deg, #7c3aed, #a78bfa);
        color: #fff;
        font-weight: 700;
        font-size: .8rem;
        margin-right: 10px;
        flex-shrink: 0;
    }

    .name-cell {
        display: flex;
        align-items: center;
    }

    /* license badge */
    .license-badge {
        font-size: .75rem;
        font-weight: 600;
        color: #4f46e5;
        background: #eef2ff;
        border: 1px solid #c7d2fe;
        border-radius: 6px;
        padding: 3px 10px;
        letter-spacing: .04em;
        display: inline-block;
    }

    /* status badge */
    .badge-active {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #dcfce7;
        color: #15803d;
        border: 1px solid #bbf7d0;
        font-size: .75rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
    }

    .badge-inactive {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #f1f5f9;
        color: #64748b;
        border: 1px solid #cbd5e1;
        font-size: .75rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
    }

    /* action buttons */
    .action-group {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 1.5px solid;
        font-size: .85rem;
        text-decoration: none;
        transition: all .15s;
    }

    .btn-action:hover { transform: translateY(-1px); text-decoration: none; }

    .btn-edit {
        border-color: #bfdbfe;
        background: #eff6ff;
        color: #2563eb;
    }
    .btn-edit:hover { background: #2563eb; color: #fff; border-color: #2563eb; }

    .btn-detail {
        border-color: #d1fae5;
        background: #f0fdf4;
        color: #059669;
    }
    .btn-detail:hover { background: #059669; color: #fff; border-color: #059669; }

    .btn-del {
        border-color: #fee2e2;
        background: #fef2f2;
        color: #dc2626;
    }
    .btn-del:hover { background: #dc2626; color: #fff; border-color: #dc2626; }

    /* empty state */
    .jl-empty {
        text-align: center;
        padding: 4rem 2rem;
        color: #9ca3af;
    }

    .jl-empty .empty-icon { font-size: 3rem; margin-bottom: 1rem; }
    .jl-empty p { font-size: .9rem; }
</style>

<div class="jl-wrapper">

    @if (TempData["Error"] != null)
    {
        <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:12px 18px;margin-bottom:1rem;color:#b91c1c;font-size:.875rem;font-family:'Inter',sans-serif;">
            ⚠️ @TempData["Error"]
        </div>
    }

    <!-- HEADER -->
    <div class="jl-header">
        <div class="jl-header-left">
            <div class="jl-header-badge">🏇 Race Management System</div>
            <h1>Quản lý Jockey</h1>
            <p>Danh sách tay đua đã đăng ký trong hệ thống</p>
        </div>
        <a asp-action="Create" class="btn-add">✚ Thêm Jockey</a>
    </div>

    <!-- STATS -->
    <div class="jl-stats">
        <div class="jl-stat">
            <div class="jl-stat-icon">🏇</div>
            <div class="jl-stat-info">
                <div class="value">@totalCount</div>
                <div class="label">Tổng số</div>
            </div>
        </div>
        <div class="jl-stat">
            <div class="jl-stat-icon">✅</div>
            <div class="jl-stat-info">
                <div class="value">@activeCount</div>
                <div class="label">Đang hoạt động</div>
            </div>
        </div>
        <div class="jl-stat">
            <div class="jl-stat-icon">⏸️</div>
            <div class="jl-stat-info">
                <div class="value">@(totalCount - activeCount)</div>
                <div class="label">Tạm dừng</div>
            </div>
        </div>
    </div>

    <!-- TOOLBAR -->
    <div class="jl-toolbar">
        <div class="search-box">
            <span class="search-icon">🔍</span>
            <input type="text" id="searchInput" placeholder="Tìm theo tên, email, mã giấy phép..." />
        </div>
        <select class="filter-select" id="statusFilter">
            <option value="">Tất cả trạng thái</option>
            <option value="active">Hoạt động</option>
            <option value="inactive">Tạm dừng</option>
        </select>
    </div>

    <!-- TABLE -->
    <div class="jl-table-wrap">
        <table class="jl-table" id="jockeyTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Tay đua</th>
                    <th>Liên hệ</th>
                    <th>Mã giấy phép</th>
                    <th>Cân nặng</th>
                    <th>Ngày sinh</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8">
                            <div class="jl-empty">
                                <div class="empty-icon">🏇</div>
                                <p>Chưa có jockey nào trong hệ thống.</p>
                                <a asp-action="Create" class="btn-add" style="margin-top:.5rem;">✚ Thêm ngay</a>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    int i = 1;
                    foreach (var jockey in Model)
                    {
                        string initials = string.IsNullOrWhiteSpace(jockey.FullName)
                            ? "?"
                            : string.Join("", jockey.FullName.Split(' ').Where(w => w.Length > 0).TakeLast(2).Select(w => w[0]));
                        <tr data-name="@jockey.FullName?.ToLower()"
                            data-email="@jockey.Email?.ToLower()"
                            data-license="@jockey.LicenseCode?.ToLower()"
                            data-status="@(jockey.IsActive ? "active" : "inactive")">
                            <td><span class="row-num">@(i++)</span></td>
                            <td>
                                <div class="name-cell">
                                    <div class="jockey-avatar">@initials</div>
                                    <span class="jockey-name">@jockey.FullName</span>
                                </div>
                            </td>
                            <td>
                                <div style="font-size:.83rem; color:#374151;">@jockey.PhoneNumber</div>
                                <div style="font-size:.78rem; color:#9ca3af;">@jockey.Email</div>
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(jockey.LicenseCode))
                                {
                                    <span class="license-badge">@jockey.LicenseCode</span>
                                }
                                else
                                {
                                    <span style="color:#d1d5db; font-size:.8rem;">—</span>
                                }
                            </td>
                            <td style="font-weight:500;">
                                @(jockey.Weight.HasValue ? jockey.Weight.Value.ToString("F1") + " kg" : "—")
                            </td>
                            <td>
                                @(jockey.DateOfBirth.HasValue ? jockey.DateOfBirth.Value.ToString("dd/MM/yyyy") : "—")
                            </td>
                            <td>
                                @if (jockey.IsActive)
                                {
                                    <span class="badge-active">● Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge-inactive">● Tạm dừng</span>
                                }
                            </td>
                            <td>
                                <div class="action-group">
                                    <a asp-action="Edit" asp-route-id="@jockey.JockeyNguyenDntid" class="btn-action btn-edit" title="Chỉnh sửa">✏️</a>
                                    <a asp-action="Details" asp-route-id="@jockey.JockeyNguyenDntid" class="btn-action btn-detail" title="Chi tiết">👁</a>
                                    <a asp-action="Delete" asp-route-id="@jockey.JockeyNguyenDntid" class="btn-action btn-del" title="Xóa">🗑</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    const searchInput   = document.getElementById('searchInput');
    const statusFilter  = document.getElementById('statusFilter');
    const rows          = document.querySelectorAll('#jockeyTable tbody tr[data-name]');

    function filterTable() {
        const q      = searchInput.value.toLowerCase().trim();
        const status = statusFilter.value;

        rows.forEach(row => {
            const matchSearch = !q ||
                row.dataset.name?.includes(q) ||
                row.dataset.email?.includes(q) ||
                row.dataset.license?.includes(q);

            const matchStatus = !status || row.dataset.status === status;

            row.style.display = (matchSearch && matchStatus) ? '' : 'none';
        });
    }

    searchInput.addEventListener('input', filterTable);
    statusFilter.addEventListener('change', filterTable);
</script>
}
