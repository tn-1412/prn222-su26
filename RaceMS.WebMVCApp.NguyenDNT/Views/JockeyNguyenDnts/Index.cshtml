@using RaceMS.WebMVCApp.NguyenDNT.Models
@model IEnumerable<RaceMS.Entities.NguyenDNT.Models.JockeyNguyenDnt>

@{
    ViewData["Title"] = "Danh sách Jockey";
    int activeCount = Model.Count(j => j.IsActive);
    int totalCount  = Model.Count();
    bool canWrite = User.IsInRole(RoleNames.ChiefAccountant) || User.IsInRole(RoleNames.Accountant);
    bool canDelete = User.IsInRole(RoleNames.CanDelete);
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@@600;700&family=Inter:wght@@400;500;600&display=swap');

    .jl-wrapper {
        max-width: 1100px;
        margin: 2rem auto;
        font-family: 'Inter', sans-serif;
    }

    /* ── HEADER ── */
    .jl-header {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
        border-radius: 16px 16px 0 0;
        padding: 2rem 2.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        position: relative;
        overflow: hidden;
    }

    .jl-header::before {
        content: '';
        position: absolute;
        top: -50px; right: -50px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(139,92,246,.12);
    }

    .jl-header-left h1 {
        font-family: 'Playfair Display', serif;
        color: #fff;
        font-size: 1.8rem;
        font-weight: 700;
        margin: 0 0 .25rem;
    }

    .jl-header-left p {
        color: #94a3b8;
        font-size: .875rem;
        margin: 0;
    }

    .jl-header-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(139,92,246,.2);
        border: 1px solid rgba(139,92,246,.4);
        color: #c4b5fd;
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        padding: 3px 10px;
        border-radius: 20px;
        margin-bottom: .6rem;
    }

    .btn-add {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: linear-gradient(135deg, #7c3aed, #6d28d9);
        color: #fff;
        font-size: .875rem;
        font-weight: 600;
        padding: 10px 22px;
        border-radius: 10px;
        border: none;
        text-decoration: none;
        white-space: nowrap;
        box-shadow: 0 4px 14px rgba(109,40,217,.4);
        transition: all .2s;
        position: relative;
        z-index: 1;
    }

    .btn-add:hover {
        background: linear-gradient(135deg, #6d28d9, #5b21b6);
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(109,40,217,.5);
        text-decoration: none;
    }

    /* ── STATS BAR ── */
    .jl-stats {
        display: flex;
        gap: 1px;
        background: #e9d5ff;
    }

    .jl-stat {
        flex: 1;
        background: #faf5ff;
        padding: .9rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .jl-stat-icon {
        font-size: 1.4rem;
        line-height: 1;
    }

    .jl-stat-info .value {
        font-size: 1.3rem;
        font-weight: 700;
        color: #1e1b4b;
        line-height: 1.1;
    }

    .jl-stat-info .label {
        font-size: .72rem;
        color: #7c3aed;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    /* ── SEARCH BAR ── */
    .jl-toolbar {
        background: #fff;
        border-left: 1px solid #e2e8f0;
        border-right: 1px solid #e2e8f0;
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .search-box {
        position: relative;
        flex: 1;
        min-width: 200px;
    }

    .search-box input {
        width: 100%;
        padding: 8px 14px 8px 38px;
        border: 1.5px solid #d1d5db;
        border-radius: 8px;
        font-size: .875rem;
        font-family: 'Inter', sans-serif;
        color: #111827;
        background: #f9fafb;
        transition: border-color .2s, box-shadow .2s;
        box-sizing: border-box;
    }

    .search-box input:focus {
        outline: none;
        border-color: #8b5cf6;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(139,92,246,.1);
    }

    .search-box .search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
        font-size: .9rem;
        pointer-events: none;
    }

    .search-form {
        display: flex;
        align-items: center;
        gap: .6rem;
        flex: 1;
        min-width: 280px;
        flex-wrap: wrap;
    }

    .btn-search {
        padding: 8px 18px;
        border: none;
        border-radius: 8px;
        background: linear-gradient(135deg, #7c3aed, #6d28d9);
        color: #fff;
        font-size: .875rem;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
        white-space: nowrap;
        transition: all .2s;
    }

    .btn-search:hover {
        background: linear-gradient(135deg, #6d28d9, #5b21b6);
        transform: translateY(-1px);
    }

    .btn-clear {
        font-size: .82rem;
        font-weight: 600;
        color: #dc2626;
        text-decoration: none;
        white-space: nowrap;
    }

    .btn-clear:hover { color: #b91c1c; text-decoration: underline; }

    .filter-select {
        padding: 8px 12px;
        border: 1.5px solid #d1d5db;
        border-radius: 8px;
        font-size: .875rem;
        font-family: 'Inter', sans-serif;
        color: #374151;
        background: #f9fafb;
        cursor: pointer;
    }

    .filter-select:focus {
        outline: none;
        border-color: #8b5cf6;
        box-shadow: 0 0 0 3px rgba(139,92,246,.1);
    }

    /* ── TABLE ── */
    .jl-table-wrap {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-top: none;
        border-radius: 0 0 16px 16px;
        overflow-x: auto;
        overflow-y: hidden;
        box-shadow: 0 10px 40px rgba(0,0,0,.07);
    }

    .jl-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .875rem;
    }

    .jl-table thead {
        background: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #4338ca 100%);
    }

    .jl-table thead th {
        padding: 13px 16px;
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: rgba(255,255,255,.88);
        white-space: nowrap;
        border-bottom: 3px solid transparent;
    }

    .jl-table thead th:nth-child(1) { border-bottom-color: #fbbf24; }
    .jl-table thead th:nth-child(2) { border-bottom-color: #22d3ee; }
    .jl-table thead th:nth-child(3) { border-bottom-color: #34d399; }
    .jl-table thead th:nth-child(4) { border-bottom-color: #f87171; }
    .jl-table thead th:nth-child(5) { border-bottom-color: #c084fc; }
    .jl-table thead th:nth-child(6) { border-bottom-color: #fb923c; }
    .jl-table thead th:nth-child(7) { border-bottom-color: #38bdf8; }
    .jl-table thead th:nth-child(8) { border-bottom-color: #a78bfa; }

    .jl-table thead th:first-child { padding-left: 1.5rem; }
    .jl-table thead th:last-child  { padding-right: 1.5rem; text-align: center; }

    /* ── PAGINATION OVERRIDE ── */
    .page-list-table-jockeyTable {
        margin-top: 20px !important;
        display: flex !important;
        align-items: center !important;
        gap: 5px !important;
        flex-wrap: wrap;
        padding: 4px 0;
    }

    .table-pagination-pagination-num-jockeyTable,
    .table-pagination-prev-btn-jockeyTable,
    .table-pagination-next-btn-jockeyTable {
        min-width: 38px !important;
        height: 38px !important;
        border-radius: 10px !important;
        border: 2px solid #e2e8f0 !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        font-size: .85rem !important;
        font-weight: 600 !important;
        padding: 0 10px !important;
        transition: all .18s !important;
        background: #fff !important;
    }

    .table-pagination-pagination-num-jockeyTable:hover,
    .table-pagination-prev-btn-jockeyTable:hover,
    .table-pagination-next-btn-jockeyTable:hover {
        border-color: #7c3aed !important;
        background: #f5f3ff !important;
        transform: translateY(-2px) !important;
        box-shadow: 0 4px 12px rgba(124,58,237,.2) !important;
    }

    .table-pagination-pagination-num-jockeyTable.active {
        background: linear-gradient(135deg, #7c3aed, #4f46e5) !important;
        border-color: transparent !important;
        color: #fff !important;
        box-shadow: 0 4px 14px rgba(124,58,237,.45) !important;
        transform: translateY(-1px);
    }

    .more-btn-first-jockeyTable,
    .more-btn-last-jockeyTable {
        color: #9ca3af !important;
        font-size: 1rem !important;
        padding: 0 2px !important;
        align-self: flex-end;
        line-height: 1;
    }

    .table-pagination-jump-container-jockeyTable {
        margin-left: auto !important;
        display: flex !important;
        align-items: center !important;
        gap: 6px !important;
        font-size: .82rem !important;
        font-weight: 600 !important;
        color: #6b7280 !important;
    }

    .table-pagination-jump-input-jockeyTable {
        width: 44px !important;
        height: 38px !important;
        border: 2px solid #e2e8f0 !important;
        border-radius: 10px !important;
        text-align: center !important;
        font-size: .875rem !important;
        font-weight: 700 !important;
        color: #4338ca !important;
        background: #f5f3ff !important;
        outline: none !important;
    }

    .table-pagination-jump-input-jockeyTable:focus {
        border-color: #7c3aed !important;
        box-shadow: 0 0 0 3px rgba(124,58,237,.15) !important;
    }

    .jl-table tbody tr {
        border-bottom: 1px solid #f1f5f9;
        transition: background .15s;
    }

    .jl-table tbody tr:last-child { border-bottom: none; }
    .jl-table tbody tr:hover { background: #faf5ff; }

    .jl-table tbody td {
        padding: 13px 16px;
        color: #374151;
        vertical-align: middle;
    }

    .jl-table tbody td:first-child { padding-left: 1.5rem; }
    .jl-table tbody td:last-child  { padding-right: 1.5rem; }

    /* row number */
    .row-num {
        font-size: .72rem;
        font-weight: 700;
        color: #a78bfa;
        background: #f5f3ff;
        border-radius: 6px;
        padding: 2px 8px;
        display: inline-block;
    }

    /* name cell */
    .jockey-name {
        font-weight: 600;
        color: #1e1b4b;
    }

    .jockey-avatar {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: linear-gradient(135deg, #7c3aed, #a78bfa);
        color: #fff;
        font-weight: 700;
        font-size: .8rem;
        margin-right: 10px;
        flex-shrink: 0;
    }

    .name-cell {
        display: flex;
        align-items: center;
    }

    /* license badge */
    .license-badge {
        font-size: .75rem;
        font-weight: 600;
        color: #4f46e5;
        background: #eef2ff;
        border: 1px solid #c7d2fe;
        border-radius: 6px;
        padding: 3px 10px;
        letter-spacing: .04em;
        display: inline-block;
    }

    /* status badge */
    .badge-active {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #dcfce7;
        color: #15803d;
        border: 1px solid #bbf7d0;
        font-size: .75rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
    }

    .badge-inactive {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #f1f5f9;
        color: #64748b;
        border: 1px solid #cbd5e1;
        font-size: .75rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
    }

    /* action buttons */
    .action-group {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 1.5px solid;
        font-size: .85rem;
        text-decoration: none;
        transition: all .15s;
    }

    .btn-action:hover { transform: translateY(-1px); text-decoration: none; }

    .btn-edit {
        border-color: #bfdbfe;
        background: #eff6ff;
        color: #2563eb;
    }
    .btn-edit:hover { background: #2563eb; color: #fff; border-color: #2563eb; }

    .btn-detail {
        border-color: #d1fae5;
        background: #f0fdf4;
        color: #059669;
    }
    .btn-detail:hover { background: #059669; color: #fff; border-color: #059669; }

    .btn-del {
        border-color: #fee2e2;
        background: #fef2f2;
        color: #dc2626;
    }
    .btn-del:hover { background: #dc2626; color: #fff; border-color: #dc2626; }

    /* empty state */
    .jl-empty {
        text-align: center;
        padding: 4rem 2rem;
        color: #9ca3af;
    }

    .jl-empty .empty-icon { font-size: 3rem; margin-bottom: 1rem; }
    .jl-empty p { font-size: .9rem; }
</style>

<div class="jl-wrapper">

    <!-- HEADER -->
    <div class="jl-header">
        <div class="jl-header-left">
            <div class="jl-header-badge">🏇 Race Management System</div>
            <h1>Quản lý Jockey</h1>
            <p>Danh sách tay đua đã đăng ký trong hệ thống</p>
        </div>
        @if (canWrite)
        {
            <a asp-action="Create" class="btn-add">✚ Thêm Jockey</a>
        }
    </div>

    <!-- STATS -->
    <div class="jl-stats">
        <div class="jl-stat">
            <div class="jl-stat-icon">🏇</div>
            <div class="jl-stat-info">
                <div class="value">@totalCount</div>
                <div class="label">Tổng số</div>
            </div>
        </div>
        <div class="jl-stat">
            <div class="jl-stat-icon">✅</div>
            <div class="jl-stat-info">
                <div class="value">@activeCount</div>
                <div class="label">Đang hoạt động</div>
            </div>
        </div>
        <div class="jl-stat">
            <div class="jl-stat-icon">⏸️</div>
            <div class="jl-stat-info">
                <div class="value">@(totalCount - activeCount)</div>
                <div class="label">Tạm dừng</div>
            </div>
        </div>
    </div>

    <!-- TOOLBAR -->
    <div class="jl-toolbar" style="flex-direction:column; align-items:stretch;">
        @* [SEARCH] Form GET → JockeyNguyenDnts/Index?fullName=..&email=..&licenseCode=.. (search phía server, AND giữa các ô có nhập) *@
        <form asp-action="Index" method="get" class="search-form" style="width:100%;">
            <div class="search-box">
                <span class="search-icon">👤</span>
                <input type="text" name="fullName"
                       value="@ViewData["FullName"]"
                       placeholder="Tìm theo họ và tên..." />
            </div>
            <div class="search-box">
                <span class="search-icon">✉️</span>
                <input type="text" name="email"
                       value="@ViewData["Email"]"
                       placeholder="Tìm theo email..." />
            </div>
            <div class="search-box">
                <span class="search-icon">🪪</span>
                <input type="text" name="licenseCode"
                       value="@ViewData["LicenseCode"]"
                       placeholder="Tìm theo mã giấy phép..." />
            </div>
            <button type="submit" class="btn-search">Tìm kiếm</button>
            @if (!string.IsNullOrEmpty(ViewData["FullName"] as string) ||
                 !string.IsNullOrEmpty(ViewData["Email"] as string) ||
                 !string.IsNullOrEmpty(ViewData["LicenseCode"] as string))
            {
                <a asp-action="Index" class="btn-clear">✕ Xóa lọc</a>
            }
            <select class="filter-select" id="statusFilter">
                <option value="">Tất cả trạng thái</option>
                <option value="active">Hoạt động</option>
                <option value="inactive">Tạm dừng</option>
            </select>
        </form>
    </div>

    <!-- TABLE -->
    <div class="jl-table-wrap">
        <table class="jl-table" id="jockeyTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Tay đua</th>
                    <th>Liên hệ</th>
                    <th>Mã giấy phép</th>
                    <th>Cân nặng</th>
                    <th>Ngày sinh</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody id="jockeyTableBody">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8">
                            <div class="jl-empty">
                                @{
                                    bool hasFilter = !string.IsNullOrEmpty(ViewData["FullName"] as string) ||
                                                      !string.IsNullOrEmpty(ViewData["Email"] as string) ||
                                                      !string.IsNullOrEmpty(ViewData["LicenseCode"] as string);
                                }
                                @if (hasFilter)
                                {
                                    <div class="empty-icon">🔍</div>
                                    <p>Không tìm thấy jockey nào khớp với điều kiện tìm kiếm.</p>
                                    <a asp-action="Index" class="btn-add" style="margin-top:.5rem;">↩ Xem tất cả</a>
                                }
                                else
                                {
                                    <div class="empty-icon">🏇</div>
                                    <p>Chưa có jockey nào trong hệ thống.</p>
                                    <a asp-action="Create" class="btn-add" style="margin-top:.5rem;">✚ Thêm ngay</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    int i = 1;
                    foreach (var jockey in Model)
                    {
                        string initials = string.IsNullOrWhiteSpace(jockey.FullName)
                            ? "?"
                            : string.Join("", jockey.FullName.Split(' ').Where(w => w.Length > 0).TakeLast(2).Select(w => w[0]));
                        @* [DELETE FLOW - STEP 4] id="jockey-row-{id}" là target để JS xóa row khỏi DOM khi nhận sự kiện từ SignalR *@
                        <tr id="jockey-row-@jockey.JockeyNguyenDntid"
                            data-name="@jockey.FullName?.ToLower()"
                            data-email="@jockey.Email?.ToLower()"
                            data-license="@jockey.LicenseCode?.ToLower()"
                            data-status="@(jockey.IsActive ? "active" : "inactive")">
                            <td><span class="row-num">@(i++)</span></td>
                            <td>
                                <div class="name-cell">
                                    <div class="jockey-avatar">@initials</div>
                                    <span class="jockey-name">@jockey.FullName</span>
                                </div>
                            </td>
                            <td>
                                <div style="font-size:.83rem; color:#374151;">@jockey.PhoneNumber</div>
                                <div style="font-size:.78rem; color:#9ca3af;">@jockey.Email</div>
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(jockey.LicenseCode))
                                {
                                    <span class="license-badge">@jockey.LicenseCode</span>
                                }
                                else
                                {
                                    <span style="color:#d1d5db; font-size:.8rem;">—</span>
                                }
                            </td>
                            <td style="font-weight:500;">
                                @(jockey.Weight.HasValue ? jockey.Weight.Value.ToString("F1") + " kg" : "—")
                            </td>
                            <td>
                                @(jockey.DateOfBirth.HasValue ? jockey.DateOfBirth.Value.ToString("dd/MM/yyyy") : "—")
                            </td>
                            <td>
                                @if (jockey.IsActive)
                                {
                                    <span class="badge-active">● Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge-inactive">● Tạm dừng</span>
                                }
                            </td>
                            <td>
                                <div class="action-group">
                                    @if (canWrite)
                                    {
                                        <a asp-action="Edit" asp-route-id="@jockey.JockeyNguyenDntid" class="btn-action btn-edit" title="Chỉnh sửa">✏️</a>
                                    }
                                    <a asp-action="Details" asp-route-id="@jockey.JockeyNguyenDntid" class="btn-action btn-detail" title="Chi tiết">👁</a>
                                    @* [DELETE FLOW - STEP 1] invoke HubDelete_JockeyNguyenDnt qua SignalR — chỉ ChiefAccountant mới thấy nút *@
                                    @if (canDelete)
                                    {
                                        <button class="btn-action btn-del" title="Xóa"
                                                onclick="openDeleteModal(this)"
                                                data-id="@jockey.JockeyNguyenDntid"
                                                data-name="@jockey.FullName"
                                                data-phone="@jockey.PhoneNumber"
                                                data-email="@jockey.Email"
                                                data-license="@jockey.LicenseCode"
                                                data-weight="@(jockey.Weight.HasValue ? jockey.Weight.Value.ToString("F1") + " kg" : "—")"
                                                data-dob="@(jockey.DateOfBirth.HasValue ? jockey.DateOfBirth.Value.ToString("dd/MM/yyyy") : "—")"
                                                data-status="@(jockey.IsActive ? "Hoạt động" : "Tạm dừng")">🗑</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- DELETE CONFIRM MODAL -->
<div id="deleteModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:#fff; border-radius:16px; width:100%; max-width:480px; margin:1rem; box-shadow:0 20px 60px rgba(0,0,0,.3); overflow:hidden;">
        <div style="background:linear-gradient(135deg,#7f1d1d,#dc2626); padding:1.5rem 2rem; display:flex; align-items:center; gap:12px;">
            <span style="font-size:1.6rem;">🗑</span>
            <div>
                <div style="color:#fff; font-weight:700; font-size:1.1rem;">Xác nhận xóa Jockey</div>
                <div style="color:#fca5a5; font-size:.8rem;">Hành động này không thể hoàn tác</div>
            </div>
        </div>
        <div style="padding:1.5rem 2rem;">
            <p style="font-size:.85rem; color:#6b7280; margin-bottom:1.2rem;">Bạn đang chuẩn bị xóa jockey sau khỏi hệ thống:</p>
            <div style="background:#faf5ff; border:1px solid #e9d5ff; border-radius:12px; padding:1.2rem; display:grid; grid-template-columns:1fr 1fr; gap:.7rem .5rem; font-size:.85rem;">
                <div style="color:#6b7280;">👤 Họ và tên</div>      <div id="modal-name"    style="font-weight:600; color:#1e1b4b;"></div>
                <div style="color:#6b7280;">📞 Điện thoại</div>     <div id="modal-phone"   style="font-weight:500; color:#374151;"></div>
                <div style="color:#6b7280;">✉️ Email</div>           <div id="modal-email"   style="font-weight:500; color:#374151;"></div>
                <div style="color:#6b7280;">🪪 Giấy phép</div>      <div id="modal-license" style="font-weight:500; color:#4f46e5;"></div>
                <div style="color:#6b7280;">⚖️ Cân nặng</div>       <div id="modal-weight"  style="font-weight:500; color:#374151;"></div>
                <div style="color:#6b7280;">🎂 Ngày sinh</div>      <div id="modal-dob"     style="font-weight:500; color:#374151;"></div>
                <div style="color:#6b7280;">📌 Trạng thái</div>     <div id="modal-status"  style="font-weight:500; color:#374151;"></div>
            </div>
        </div>
        <div style="padding:1rem 2rem 1.5rem; display:flex; justify-content:flex-end; gap:.75rem; border-top:1px solid #f1f5f9;">
            <button onclick="closeDeleteModal()" style="padding:9px 20px; border-radius:8px; border:1.5px solid #d1d5db; background:#fff; color:#374151; font-size:.875rem; font-weight:600; cursor:pointer;">
                ✕ Hủy
            </button>
            <button id="btnConfirmDelete" onclick="confirmDelete()" style="padding:9px 20px; border-radius:8px; border:none; background:linear-gradient(135deg,#dc2626,#b91c1c); color:#fff; font-size:.875rem; font-weight:600; cursor:pointer; box-shadow:0 4px 12px rgba(220,38,38,.35);">
                🗑 Xác nhận xóa
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/signalr/dist/browser/signalr.min.js"></script>
<script src="~/lib/table-pagination/table-pagination.js"></script>
<script>
    "use strict";

    // Quyền của user hiện tại — dùng để ẩn nút Edit/Delete trên row mới do SignalR broadcast tới
    const canWrite = @Html.Raw(canWrite.ToString().ToLowerInvariant());
    const canDelete = @Html.Raw(canDelete.ToString().ToLowerInvariant());

    // [DELETE FLOW - STEP 2] Khởi tạo kết nối WebSocket tới MSRaceHub
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/msRaceHub", { withCredentials: true })
        .build();

    function adjustStats(totalDelta, activeDelta) {
        var values = document.querySelectorAll(".jl-stat-info .value");
        if (values.length < 3) return;

        var total = parseInt(values[0].textContent) || 0;
        var active = parseInt(values[1].textContent) || 0;

        total += totalDelta;
        active += activeDelta;

        values[0].textContent = total;
        values[1].textContent = active;
        values[2].textContent = total - active;
    }

    // [DELETE FLOW - STEP 3] Lắng nghe broadcast từ server sau khi xóa thành công
    //   Server gọi: Clients.All.SendAsync("Receiver_DeleteJockeyNguyenDnt", jockeyId)
    //   → tất cả browser đang mở trang đều nhận và xóa row tương ứng
    connection.on("Receiver_DeleteJockeyNguyenDnt", function (jockeyId) {
        // [DELETE FLOW - STEP 4] Tìm <tr id="jockey-row-{id}"> trong tbody và remove khỏi DOM
        var row = document.getElementById(`jockey-row-${jockeyId}`);
        if (!row) return;

        adjustStats(-1, row.dataset.status === "active" ? -1 : 0);
        row.remove();
    });

    connection.on("DeleteError", function (message) {
        const text = message.startsWith(":") ? message.slice(1) : message;
        showToast(text, "error");
    });

    connection.on("Receiver_EditJockeyNguyenDnt", function (item) {
        var row = document.getElementById(`jockey-row-${item.jockeyNguyenDntid}`);
        if (!row) return;

        var oldStatus = row.dataset.status;
        var initials = item.fullName
            ? item.fullName.trim().split(' ').filter(w => w).slice(-2).map(w => w[0]).join('')
            : '?';
        var statusText = item.isActive ? 'Hoạt động' : 'Tạm dừng';
        var statusBadge = item.isActive
            ? '<span class="badge-active">● Hoạt động</span>'
            : '<span class="badge-inactive">● Tạm dừng</span>';
        var licenseBadge = item.licenseCode
            ? `<span class="license-badge">${item.licenseCode}</span>`
            : '<span style="color:#d1d5db;font-size:.8rem;">—</span>';
        var weight = item.weight ? Number(item.weight).toFixed(1) + ' kg' : '—';
        var dob = item.dateOfBirth
            ? new Date(item.dateOfBirth).toLocaleDateString('vi-VN') : '—';

        row.dataset.name = (item.fullName || '').toLowerCase();
        row.dataset.email = (item.email || '').toLowerCase();
        row.dataset.license = (item.licenseCode || '').toLowerCase();
        row.dataset.status = item.isActive ? 'active' : 'inactive';
        if (oldStatus !== row.dataset.status) {
            adjustStats(0, row.dataset.status === "active" ? 1 : -1);
        }

        row.cells[1].innerHTML = `
            <div class="name-cell">
                <div class="jockey-avatar">${initials}</div>
                <span class="jockey-name">${item.fullName || ''}</span>
            </div>`;
        row.cells[2].innerHTML = `
            <div style="font-size:.83rem;color:#374151;">${item.phoneNumber || ''}</div>
            <div style="font-size:.78rem;color:#9ca3af;">${item.email || ''}</div>`;
        row.cells[3].innerHTML = licenseBadge;
        row.cells[4].textContent = weight;
        row.cells[4].style.fontWeight = "500";
        row.cells[5].textContent = dob;
        row.cells[6].innerHTML = statusBadge;

        var deleteButton = row.querySelector(".btn-del");
        if (deleteButton) {
            deleteButton.dataset.name = item.fullName || '';
            deleteButton.dataset.phone = item.phoneNumber || '';
            deleteButton.dataset.email = item.email || '';
            deleteButton.dataset.license = item.licenseCode || '';
            deleteButton.dataset.weight = weight;
            deleteButton.dataset.dob = dob;
            deleteButton.dataset.status = statusText;
        }
    });

    // [CREATE FLOW] Lắng nghe broadcast từ server khi có jockey mới được tạo
    //   Server gọi: Clients.All.SendAsync("Receiver_CreateJockeyNguyenDnt", jockey)
    //   → tất cả browser đang mở trang Index đều nhận object và prepend row mới vào bảng
    connection.on("Receiver_CreateJockeyNguyenDnt", function (item) {
        var initials = item.fullName
            ? item.fullName.trim().split(' ').filter(w => w).slice(-2).map(w => w[0]).join('')
            : '?';
        var statusBadge = item.isActive
            ? '<span class="badge-active">● Hoạt động</span>'
            : '<span class="badge-inactive">● Tạm dừng</span>';
        var licenseBadge = item.licenseCode
            ? `<span class="license-badge">${item.licenseCode}</span>`
            : '<span style="color:#d1d5db;font-size:.8rem;">—</span>';
        var weight = item.weight ? item.weight.toFixed(1) + ' kg' : '—';
        var dob = item.dateOfBirth
            ? new Date(item.dateOfBirth).toLocaleDateString('vi-VN') : '—';

        var tr = `
            <tr id="jockey-row-${item.jockeyNguyenDntid}"
                data-name="${(item.fullName || '').toLowerCase()}"
                data-email="${(item.email || '').toLowerCase()}"
                data-license="${(item.licenseCode || '').toLowerCase()}"
                data-status="${item.isActive ? 'active' : 'inactive'}">
                <td><span class="row-num">★</span></td>
                <td>
                    <div class="name-cell">
                        <div class="jockey-avatar">${initials}</div>
                        <span class="jockey-name">${item.fullName || ''}</span>
                    </div>
                </td>
                <td>
                    <div style="font-size:.83rem;color:#374151;">${item.phoneNumber || ''}</div>
                    <div style="font-size:.78rem;color:#9ca3af;">${item.email || ''}</div>
                </td>
                <td>${licenseBadge}</td>
                <td style="font-weight:500;">${weight}</td>
                <td>${dob}</td>
                <td>${statusBadge}</td>
                <td>
                    <div class="action-group">
                        ${canWrite ? `<a href="/JockeyNguyenDnts/Edit/${item.jockeyNguyenDntid}" class="btn-action btn-edit" title="Chỉnh sửa">✏️</a>` : ''}
                        <a href="/JockeyNguyenDnts/Details/${item.jockeyNguyenDntid}" class="btn-action btn-detail" title="Chi tiết">👁</a>
                        ${canDelete ? `<button onclick="openDeleteModal(this)" class="btn-action btn-del" title="Xóa"
                                data-id="${item.jockeyNguyenDntid}"
                                data-name="${item.fullName || ''}"
                                data-phone="${item.phoneNumber || ''}"
                                data-email="${item.email || ''}"
                                data-license="${item.licenseCode || ''}"
                                data-weight="${weight}"
                                data-dob="${dob}"
                                data-status="${item.isActive ? 'Hoạt động' : 'Tạm dừng'}">🗑</button>` : ''}
                    </div>
                </td>
            </tr>`;

        $('#jockeyTableBody').prepend(tr);
        adjustStats(1, item.isActive ? 1 : 0);
    });

    connection.start().catch(err => console.error(err.toString()));

    // [DELETE FLOW - STEP 1] Mở modal confirm với đầy đủ thông tin jockey
    var _pendingDeleteId = null;

    function openDeleteModal(btn) {
        _pendingDeleteId = btn.dataset.id;
        document.getElementById("modal-name").textContent    = btn.dataset.name    || "—";
        document.getElementById("modal-phone").textContent   = btn.dataset.phone   || "—";
        document.getElementById("modal-email").textContent   = btn.dataset.email   || "—";
        document.getElementById("modal-license").textContent = btn.dataset.license || "—";
        document.getElementById("modal-weight").textContent  = btn.dataset.weight  || "—";
        document.getElementById("modal-dob").textContent     = btn.dataset.dob     || "—";
        document.getElementById("modal-status").textContent  = btn.dataset.status  || "—";
        document.getElementById("deleteModal").style.display = "flex";
    }

    function closeDeleteModal() {
        document.getElementById("deleteModal").style.display = "none";
        _pendingDeleteId = null;
    }

    function confirmDelete() {
        if (!_pendingDeleteId) return;

        if (connection.state !== signalR.HubConnectionState.Connected) {
            showToast("Chưa kết nối được tới server, vui lòng thử lại sau giây lát.", "error");
            return;
        }

        connection.invoke("HubDelete_JockeyNguyenDnt", parseInt(_pendingDeleteId))
            .catch(err => {
                console.error(err.toString());
                showToast("Không thể xóa qua SignalR: " + err.message, "error");
            });
        closeDeleteModal();
    }

    // Đóng modal khi click ra ngoài
    document.getElementById("deleteModal").addEventListener("click", function (e) {
        if (e.target === this) closeDeleteModal();
    });
</script>
<script>
    // Tìm theo tên/email/mã giấy phép giờ là search phía server (3 ô, submit GET).
    // JS chỉ còn lo phân trang + filter nhanh theo trạng thái trên kết quả đã trả về.
    const statusFilter = document.getElementById('statusFilter');
    const rows         = document.querySelectorAll('#jockeyTable tbody tr[data-name]');

    const paginationOpts = {
        rowPerPage: 5,
        paginationColor: '#7c3aed',
        fontColor: '#6b21a8',
        paginationStyle: 'bordered',
        jumpPage: true
    };

    function initPagination() {
        $('#jockeyTable').createTablePagination(paginationOpts);
    }

    function filterByStatus() {
        const status = statusFilter.value;

        if (status) {
            // Bypass pagination: show all rows then apply filter
            $('#jockeyTable tbody tr').show();
            $('.page-list-table-jockeyTable').hide();

            rows.forEach(row => {
                row.style.display = (row.dataset.status === status) ? '' : 'none';
            });
        } else {
            // Không filter — khôi phục phân trang từ đầu
            initPagination();
        }
    }

    $(function () {
        initPagination();
    });

    statusFilter.addEventListener('change', filterByStatus);
</script>
}
