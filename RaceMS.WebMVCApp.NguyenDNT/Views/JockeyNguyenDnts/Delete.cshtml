@model RaceMS.Entities.NguyenDNT.Models.JockeyNguyenDnt

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3 class="text-danger">Are you sure you want to delete this?</h3>
<div>
    <h4>JockeyNguyenDnt</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.FullName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FullName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PhoneNumber)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PhoneNumber)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Email)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Email)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.LicenseCode)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.LicenseCode)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Weight)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Weight)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DateOfBirth)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DateOfBirth)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IsActive)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IsActive)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="JockeyNguyenDntid" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <input type="button" id="btnHubDelete" value="Delete via SignalR" class="btn btn-warning" disabled title="Đang kết nối tới server..."/>
        <a asp-action="Index">Back to List</a>
    </form>
</div>

@section Scripts {
    <script src="~/js/signalr/dist/browser/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/msRaceHub", { withCredentials: true })
            .withAutomaticReconnect()
            .build();

        const btnHubDelete = document.getElementById("btnHubDelete");

        // Nút chỉ được bấm khi kết nối THẬT SỰ đã sẵn sàng — tránh race condition
        // (bấm trước khi connection.start() xong khiến invoke() thất bại âm thầm).
        function setHubButtonReady(ready) {
            btnHubDelete.disabled = !ready;
            btnHubDelete.title = ready ? "" : "Đang kết nối tới server...";
        }

        connection.onreconnecting(() => setHubButtonReady(false));
        connection.onreconnected(() => setHubButtonReady(true));
        connection.onclose(() => setHubButtonReady(false));

        connection.on("Receiver_DeleteJockeyNguyenDnt", function (jockeyId) {
            if (parseInt(jockeyId) === @Model.JockeyNguyenDntid) {
                window.location.href = "@Url.Action("Index", "JockeyNguyenDnts")";
            }
        });

        connection.on("DeleteError", function (message) {
            const text = message && message.startsWith(":") ? message.slice(1) : message;
            showToast(text || "Xóa thất bại.", "error");
        });

        connection.start().then(function () {
            setHubButtonReady(true);
        }).catch(function (err) {
            console.error(err.toString());
            setHubButtonReady(false);
        });

        btnHubDelete.addEventListener("click", function (event) {
            event.preventDefault();

            if (connection.state !== signalR.HubConnectionState.Connected) {
                showToast("Chưa kết nối được tới server, vui lòng thử lại sau giây lát.", "error");
                return;
            }

            const id = @Model.JockeyNguyenDntid;
            connection.invoke("HubDelete_JockeyNguyenDnt", id).catch(function (err) {
                console.error(err.toString());
                showToast("Không thể xóa qua SignalR: " + err.message, "error");
            });
        });
    </script>
}