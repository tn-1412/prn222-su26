@{
    ViewData["Title"] = "Chat";
    var currentUser = User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value
                   ?? User.Identity?.Name
                   ?? "Unknown";
}

<style>
    .chat-wrapper {
        max-width: 860px;
        margin: 2rem auto;
        font-family: 'Inter', sans-serif;
    }

    .chat-header {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
        border-radius: 16px 16px 0 0;
        padding: 1.5rem 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .chat-header h2 {
        color: #fff;
        margin: 0;
        font-size: 1.4rem;
        font-weight: 700;
    }

    .chat-header .status-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #6b7280;
        display: inline-block;
        margin-right: 6px;
        transition: background .3s;
    }

    .chat-header .status-dot.connected { background: #22c55e; }

    .chat-header .status-text {
        color: #94a3b8;
        font-size: .8rem;
    }

    .chat-body {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-top: none;
        border-radius: 0 0 16px 16px;
        display: flex;
        flex-direction: column;
        height: 520px;
    }

    .messages-area {
        flex: 1;
        overflow-y: auto;
        padding: 1.2rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: .6rem;
    }

    .msg {
        display: flex;
        flex-direction: column;
        max-width: 72%;
    }

    .msg.mine { align-self: flex-end; align-items: flex-end; }
    .msg.other { align-self: flex-start; align-items: flex-start; }

    .msg-meta {
        font-size: .72rem;
        color: #9ca3af;
        margin-bottom: 2px;
    }

    .msg-bubble {
        padding: 8px 14px;
        border-radius: 16px;
        font-size: .875rem;
        line-height: 1.45;
        word-break: break-word;
    }

    .msg.mine .msg-bubble {
        background: linear-gradient(135deg, #7c3aed, #6d28d9);
        color: #fff;
        border-bottom-right-radius: 4px;
    }

    .msg.other .msg-bubble {
        background: #f1f5f9;
        color: #1e293b;
        border-bottom-left-radius: 4px;
    }

    .msg-system {
        align-self: center;
        font-size: .75rem;
        color: #9ca3af;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        padding: 3px 12px;
        font-style: italic;
    }

    .chat-input-area {
        border-top: 1px solid #e2e8f0;
        padding: 1rem 1.5rem;
        display: flex;
        gap: .75rem;
        align-items: center;
    }

    .chat-input-area input[type="text"] {
        flex: 1;
        padding: 10px 16px;
        border: 1.5px solid #d1d5db;
        border-radius: 24px;
        font-size: .875rem;
        outline: none;
        transition: border-color .2s, box-shadow .2s;
        font-family: inherit;
    }

    .chat-input-area input[type="text"]:focus {
        border-color: #7c3aed;
        box-shadow: 0 0 0 3px rgba(124,58,237,.1);
    }

    .btn-send {
        background: linear-gradient(135deg, #7c3aed, #6d28d9);
        color: #fff;
        border: none;
        border-radius: 24px;
        padding: 10px 22px;
        font-size: .875rem;
        font-weight: 600;
        cursor: pointer;
        transition: opacity .2s, transform .1s;
        white-space: nowrap;
    }

    .btn-send:disabled { opacity: .45; cursor: not-allowed; }
    .btn-send:not(:disabled):hover { opacity: .9; transform: translateY(-1px); }
</style>

<div class="chat-wrapper">

    <div class="chat-header">
        <div style="flex:1">
            <h2>💬 RaceMS Chat</h2>
            <span class="status-text">
                <span class="status-dot" id="statusDot"></span>
                <span id="statusText">Đang kết nối...</span>
            </span>
        </div>
        <div style="color:#94a3b8; font-size:.85rem;">
            Bạn: <strong style="color:#c4b5fd;">@currentUser</strong>
        </div>
    </div>

    <div class="chat-body">
        <div class="messages-area" id="messagesArea"></div>

        <div class="chat-input-area">
            <input type="text" id="messageInput" placeholder="Nhập tin nhắn..." disabled maxlength="500" />
            <button class="btn-send" id="sendButton" disabled>Gửi</button>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/signalr/dist/browser/signalr.min.js"></script>
<script>
    "use strict";

    const currentUser = "@Html.Raw(Html.Encode(currentUser))";
    const messagesArea = document.getElementById("messagesArea");
    const messageInput = document.getElementById("messageInput");
    const sendButton   = document.getElementById("sendButton");
    const statusDot    = document.getElementById("statusDot");
    const statusText   = document.getElementById("statusText");

    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .withAutomaticReconnect()
        .build();

    // ── Receive message ──
    connection.on("ReceiveMessage", function (user, message, timestamp) {
        const isMine = user === currentUser;
        const div = document.createElement("div");
        div.className = "msg " + (isMine ? "mine" : "other");
        div.innerHTML =
            `<div class="msg-meta">${escapeHtml(user)} · ${escapeHtml(timestamp)}</div>
             <div class="msg-bubble">${escapeHtml(message)}</div>`;
        messagesArea.appendChild(div);
        messagesArea.scrollTop = messagesArea.scrollHeight;
    });

    // ── User connected/disconnected ──
    connection.on("UserConnected", function (user) {
        appendSystem(escapeHtml(user) + " đã tham gia chat");
    });

    connection.on("UserDisconnected", function (user) {
        appendSystem(escapeHtml(user) + " đã rời khỏi chat");
    });

    // ── Reconnecting states ──
    connection.onreconnecting(() => {
        setStatus(false, "Đang kết nối lại...");
    });

    connection.onreconnected(() => {
        setStatus(true, "Đã kết nối");
    });

    connection.onclose(() => {
        setStatus(false, "Mất kết nối");
        sendButton.disabled = true;
        messageInput.disabled = true;
    });

    // ── Start connection ──
    connection.start()
        .then(() => {
            setStatus(true, "Đã kết nối");
            sendButton.disabled = false;
            messageInput.disabled = false;
            messageInput.focus();
        })
        .catch(err => {
            setStatus(false, "Lỗi kết nối");
            console.error(err.toString());
        });

    // ── Send ──
    function sendMessage() {
        const msg = messageInput.value.trim();
        if (!msg) return;
        connection.invoke("SendMessage", msg).catch(err => console.error(err.toString()));
        messageInput.value = "";
        messageInput.focus();
    }

    sendButton.addEventListener("click", sendMessage);

    messageInput.addEventListener("keydown", function (e) {
        if (e.key === "Enter" && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    // ── Helpers ──
    function appendSystem(text) {
        const div = document.createElement("div");
        div.className = "msg-system";
        div.textContent = text;
        messagesArea.appendChild(div);
        messagesArea.scrollTop = messagesArea.scrollHeight;
    }

    function setStatus(online, text) {
        statusDot.className  = "status-dot" + (online ? " connected" : "");
        statusText.textContent = text;
    }

    function escapeHtml(str) {
        return String(str)
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;");
    }
</script>
}
