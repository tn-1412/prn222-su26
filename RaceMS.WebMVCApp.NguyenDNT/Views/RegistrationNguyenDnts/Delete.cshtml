@model RaceMS.Entities.NguyenDNT.Models.RegistrationNguyenDnt

@{
    ViewData["Title"] = "Xóa đăng ký";
}

<h1>Xóa đăng ký</h1>

<h3 class="text-danger">Bạn có chắc chắn muốn xóa đăng ký này?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.RaceName)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.RaceName)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.HorseName)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.HorseName)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.PrizeMoney)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.PrizeMoney)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.JockeyNguyenDntid)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.JockeyNguyenDntid)</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="RegistrationNguyenDntid" />
        <input type="submit" value="Xóa" class="btn btn-danger" /> |
        <button type="button" id="btnHubDelete" class="btn btn-warning" disabled title="Đang kết nối tới server...">Xóa via SignalR</button>
        <a asp-action="Index">Quay lại danh sách</a>
    </form>
</div>

@section Scripts {
    <script src="~/js/signalr/dist/browser/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/msRaceHub", { withCredentials: true })
            .withAutomaticReconnect()
            .build();

        const btnHubDelete = document.getElementById("btnHubDelete");

        // Nút chỉ được bấm khi kết nối THẬT SỰ đã sẵn sàng — tránh race condition
        // (bấm trước khi connection.start() xong khiến invoke() thất bại âm thầm).
        function setHubButtonReady(ready) {
            btnHubDelete.disabled = !ready;
            btnHubDelete.title = ready ? "" : "Đang kết nối tới server...";
        }

        connection.onreconnecting(() => setHubButtonReady(false));
        connection.onreconnected(() => setHubButtonReady(true));
        connection.onclose(() => setHubButtonReady(false));

        connection.on("Receiver_DeleteRegistrationNguyenDnt", function (id) {
            if (parseInt(id) === @Model.RegistrationNguyenDntid) {
                window.location.href = "@Url.Action("Index", "RegistrationNguyenDnts")";
            }
        });

        connection.on("DeleteError", function (message) {
            const text = message && message.startsWith(":") ? message.slice(1) : message;
            showToast(text || "Xóa thất bại.", "error");
        });

        connection.start().then(function () {
            setHubButtonReady(true);
        }).catch(function (err) {
            console.error(err.toString());
            setHubButtonReady(false);
        });

        btnHubDelete.addEventListener("click", function (event) {
            event.preventDefault();

            if (connection.state !== signalR.HubConnectionState.Connected) {
                showToast("Chưa kết nối được tới server, vui lòng thử lại sau giây lát.", "error");
                return;
            }

            const id = @Model.RegistrationNguyenDntid;
            connection.invoke("HubDelete_RegistrationNguyenDnt", id).catch(function (err) {
                console.error(err.toString());
                showToast("Không thể xóa qua SignalR: " + err.message, "error");
            });
        });
    </script>
}
