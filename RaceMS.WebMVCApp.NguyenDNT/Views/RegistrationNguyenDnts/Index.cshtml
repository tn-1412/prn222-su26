@using RaceMS.WebMVCApp.NguyenDNT.Models
@model IEnumerable<RaceMS.Entities.NguyenDNT.Models.RegistrationNguyenDnt>

@{
    ViewData["Title"] = "Danh sách đăng ký đua";
    int totalCount = Model.Count();
    int confirmedCount = Model.Count(r => r.IsConfirmed == true);
    decimal totalPrize = Model.Sum(r => r.PrizeMoney ?? 0);
    bool canWrite = User.IsInRole(RoleNames.ChiefAccountant) || User.IsInRole(RoleNames.Accountant);
    bool canDelete = User.IsInRole(RoleNames.CanDelete);
}

<style>
    .rl-wrapper {
        max-width: 1150px;
        margin: 2rem auto;
        font-family: 'Inter', sans-serif;
    }

    .rl-header {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
        border-radius: 16px 16px 0 0;
        padding: 2rem 2.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .rl-header h1 {
        color: #fff;
        font-size: 1.6rem;
        font-weight: 700;
        margin: 0 0 .25rem;
    }

    .rl-header p {
        color: #94a3b8;
        font-size: .875rem;
        margin: 0;
    }

    .rl-btn-add {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: linear-gradient(135deg, #7c3aed, #6d28d9);
        color: #fff;
        font-size: .875rem;
        font-weight: 600;
        padding: 10px 22px;
        border-radius: 10px;
        border: none;
        text-decoration: none;
        white-space: nowrap;
        box-shadow: 0 4px 14px rgba(109,40,217,.4);
    }

    .rl-btn-add:hover { color: #fff; text-decoration: none; transform: translateY(-1px); }

    /* ── STATS BAR ── */
    .rl-stats {
        display: flex;
        gap: 1px;
        background: #e9d5ff;
    }

    .rl-stat {
        flex: 1;
        background: #faf5ff;
        padding: .9rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .rl-stat-icon { font-size: 1.4rem; line-height: 1; }
    .rl-stat-info .value { font-size: 1.3rem; font-weight: 700; color: #1e1b4b; line-height: 1.1; }
    .rl-stat-info .label {
        font-size: .72rem;
        color: #7c3aed;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .rl-toolbar {
        background: #fff;
        border-left: 1px solid #e2e8f0;
        border-right: 1px solid #e2e8f0;
        padding: 1rem 1.5rem;
    }

    .rl-search-form {
        display: flex;
        align-items: center;
        gap: .6rem;
        flex-wrap: wrap;
    }

    .rl-search-form input {
        padding: 8px 14px;
        border: 1.5px solid #d1d5db;
        border-radius: 8px;
        font-size: .875rem;
        background: #f9fafb;
        min-width: 180px;
    }

    .rl-search-form input:focus {
        outline: none;
        border-color: #8b5cf6;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(139,92,246,.1);
    }

    .rl-btn-search {
        padding: 8px 18px;
        border: none;
        border-radius: 8px;
        background: linear-gradient(135deg, #7c3aed, #6d28d9);
        color: #fff;
        font-size: .875rem;
        font-weight: 600;
        cursor: pointer;
    }

    .rl-btn-clear {
        font-size: .82rem;
        font-weight: 600;
        color: #dc2626;
        text-decoration: none;
    }

    .rl-table-wrap {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-top: none;
        border-radius: 0 0 16px 16px;
        overflow-x: auto;
        box-shadow: 0 10px 40px rgba(0,0,0,.07);
    }

    .rl-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .875rem;
    }

    .rl-table thead {
        background: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #4338ca 100%);
    }

    .rl-table thead th {
        padding: 13px 16px;
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: rgba(255,255,255,.88);
        white-space: nowrap;
    }

    .rl-table tbody tr {
        border-bottom: 1px solid #f1f5f9;
    }

    .rl-table tbody tr:hover { background: #faf5ff; }

    .rl-table tbody td {
        padding: 12px 16px;
        color: #374151;
        vertical-align: middle;
    }

    .rl-empty {
        text-align: center;
        padding: 3rem 2rem;
        color: #9ca3af;
    }

    .rl-badge-confirmed {
        background: #dcfce7;
        color: #15803d;
        border: 1px solid #bbf7d0;
        font-size: .75rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
    }

    .rl-badge-pending {
        background: #f1f5f9;
        color: #64748b;
        border: 1px solid #cbd5e1;
        font-size: .75rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
    }

    .rl-horse-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .rl-horse-avatar {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: linear-gradient(135deg, #0ea5e9, #38bdf8);
        color: #fff;
        font-size: .9rem;
        flex-shrink: 0;
    }

    .rl-race-code {
        font-size: .72rem;
        font-weight: 700;
        color: #a78bfa;
        background: #f5f3ff;
        border-radius: 6px;
        padding: 2px 8px;
        display: inline-block;
    }

    .rl-action-group {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .rl-btn-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 1.5px solid;
        font-size: .85rem;
        text-decoration: none;
        cursor: pointer;
    }

    .rl-btn-edit { border-color: #bfdbfe; background: #eff6ff; color: #2563eb; }
    .rl-btn-edit:hover { background: #2563eb; color: #fff; text-decoration: none; }
    .rl-btn-detail { border-color: #d1fae5; background: #f0fdf4; color: #059669; }
    .rl-btn-detail:hover { background: #059669; color: #fff; text-decoration: none; }
    .rl-btn-del { border-color: #fee2e2; background: #fef2f2; color: #dc2626; }
    .rl-btn-del:hover { background: #dc2626; color: #fff; }

    /* ── PAGINATION OVERRIDE (đồng bộ với trang Jockey) ── */
    .page-list-table-registrationTable {
        margin-top: 20px !important;
        display: flex !important;
        align-items: center !important;
        gap: 5px !important;
        flex-wrap: wrap;
        padding: 4px 0;
    }

    .table-pagination-pagination-num-registrationTable,
    .table-pagination-prev-btn-registrationTable,
    .table-pagination-next-btn-registrationTable {
        min-width: 38px !important;
        height: 38px !important;
        border-radius: 10px !important;
        border: 2px solid #e2e8f0 !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        font-size: .85rem !important;
        font-weight: 600 !important;
        padding: 0 10px !important;
        transition: all .18s !important;
        background: #fff !important;
    }

    .table-pagination-pagination-num-registrationTable:hover,
    .table-pagination-prev-btn-registrationTable:hover,
    .table-pagination-next-btn-registrationTable:hover {
        border-color: #7c3aed !important;
        background: #f5f3ff !important;
        transform: translateY(-2px) !important;
        box-shadow: 0 4px 12px rgba(124,58,237,.2) !important;
    }

    .table-pagination-pagination-num-registrationTable.active {
        background: linear-gradient(135deg, #7c3aed, #4f46e5) !important;
        border-color: transparent !important;
        color: #fff !important;
        box-shadow: 0 4px 14px rgba(124,58,237,.45) !important;
        transform: translateY(-1px);
    }

    .more-btn-first-registrationTable,
    .more-btn-last-registrationTable {
        color: #9ca3af !important;
        font-size: 1rem !important;
        padding: 0 2px !important;
        align-self: flex-end;
        line-height: 1;
    }

    .table-pagination-jump-container-registrationTable {
        margin-left: auto !important;
        display: flex !important;
        align-items: center !important;
        gap: 6px !important;
        font-size: .82rem !important;
        font-weight: 600 !important;
        color: #6b7280 !important;
    }

    .table-pagination-jump-input-registrationTable {
        width: 44px !important;
        height: 38px !important;
        border: 2px solid #e2e8f0 !important;
        border-radius: 10px !important;
        text-align: center !important;
        font-size: .875rem !important;
        font-weight: 700 !important;
        color: #4338ca !important;
        background: #f5f3ff !important;
        outline: none !important;
    }

    .table-pagination-jump-input-registrationTable:focus {
        border-color: #7c3aed !important;
        box-shadow: 0 0 0 3px rgba(124,58,237,.15) !important;
    }
</style>

<div class="rl-wrapper">

    <div class="rl-header">
        <div>
            <h1>🏆 Danh sách đăng ký đua</h1>
            <p>Theo dõi đăng ký ngựa &amp; jockey tham gia các giải đua</p>
        </div>
        @if (canWrite)
        {
            <a asp-action="Create" class="rl-btn-add">✚ Thêm đăng ký</a>
        }
    </div>

    <!-- STATS -->
    <div class="rl-stats">
        <div class="rl-stat">
            <div class="rl-stat-icon">🏁</div>
            <div class="rl-stat-info">
                <div class="value" id="rl-total-count">@totalCount</div>
                <div class="label">Tổng số</div>
            </div>
        </div>
        <div class="rl-stat">
            <div class="rl-stat-icon">✅</div>
            <div class="rl-stat-info">
                <div class="value" id="rl-confirmed-count">@confirmedCount</div>
                <div class="label">Đã xác nhận</div>
            </div>
        </div>
        <div class="rl-stat">
            <div class="rl-stat-icon">💰</div>
            <div class="rl-stat-info">
                <div class="value" id="rl-total-prize">@totalPrize.ToString("N0")</div>
                <div class="label">Tổng tiền thưởng</div>
            </div>
        </div>
    </div>

    <!-- TOOLBAR: 3 ô search độc lập — Mã đăng ký / Tiền thưởng / Tên ngựa (AND giữa các ô có nhập) -->
    <div class="rl-toolbar">
        <form asp-action="Index" method="get" class="rl-search-form">
            <input type="number" name="code" value="@ViewData["Code"]" placeholder="Mã đăng ký..." />
            <input type="number" step="0.01" name="prizeMoney" value="@ViewData["PrizeMoney"]" placeholder="Tiền thưởng..." />
            <input type="text" name="horseName" value="@ViewData["HorseName"]" placeholder="Tên ngựa..." />
            <button type="submit" class="rl-btn-search">Tìm kiếm</button>
            @if (ViewData["Code"] != null || ViewData["PrizeMoney"] != null || !string.IsNullOrEmpty(ViewData["HorseName"] as string))
            {
                <a asp-action="Index" class="rl-btn-clear">✕ Xóa lọc</a>
            }
        </form>
    </div>

    <div class="rl-table-wrap">
        <table class="rl-table" id="registrationTable">
            <thead>
                <tr>
                    <th>Mã</th>
                    <th>Giải đua</th>
                    <th>Tên ngựa</th>
                    <th>Ngày đăng ký</th>
                    <th>Ngày phản hồi</th>
                    <th>Tiền thưởng</th>
                    <th>Trạng thái</th>
                    <th>Jockey ID</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody id="registrationTableBody">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9">
                            <div class="rl-empty">Không tìm thấy đăng ký nào khớp với điều kiện tìm kiếm.</div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var r in Model)
                    {
                        <tr id="registration-row-@r.RegistrationNguyenDntid" data-status="@(r.IsConfirmed == true ? "confirmed" : "pending")">
                            <td><span class="rl-race-code">#@r.RegistrationNguyenDntid</span></td>
                            <td>@r.RaceName</td>
                            <td>
                                <div class="rl-horse-cell">
                                    <span class="rl-horse-avatar">🐎</span>
                                    <span>@r.HorseName</span>
                                </div>
                            </td>
                            <td>@(r.RegisteredDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                            <td>@(r.ResponseDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                            <td>@(r.PrizeMoney?.ToString("N0") ?? "—")</td>
                            <td>
                                @if (r.IsConfirmed == true)
                                {
                                    <span class="rl-badge-confirmed">● Đã xác nhận</span>
                                }
                                else
                                {
                                    <span class="rl-badge-pending">● Chờ xác nhận</span>
                                }
                            </td>
                            <td>@(r.JockeyNguyenDntid?.ToString() ?? "—")</td>
                            <td>
                                <div class="rl-action-group">
                                    @if (canWrite)
                                    {
                                        <a asp-action="Edit" asp-route-id="@r.RegistrationNguyenDntid" class="rl-btn-action rl-btn-edit" title="Chỉnh sửa">✏️</a>
                                    }
                                    <a asp-action="Details" asp-route-id="@r.RegistrationNguyenDntid" class="rl-btn-action rl-btn-detail" title="Chi tiết">👁</a>
                                    @if (canDelete)
                                    {
                                        <button class="rl-btn-action rl-btn-del" title="Xóa" onclick="openDeleteModal(this)"
                                                data-id="@r.RegistrationNguyenDntid" data-race-name="@r.RaceName">🗑</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- DELETE CONFIRM MODAL -->
<div id="deleteModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:#fff; border-radius:16px; width:100%; max-width:420px; margin:1rem; box-shadow:0 20px 60px rgba(0,0,0,.3); overflow:hidden;">
        <div style="background:linear-gradient(135deg,#7f1d1d,#dc2626); padding:1.5rem 2rem;">
            <div style="color:#fff; font-weight:700; font-size:1.1rem;">🗑 Xác nhận xóa đăng ký</div>
        </div>
        <div style="padding:1.5rem 2rem;">
            <p style="font-size:.875rem; color:#374151;">Bạn có chắc muốn xóa đăng ký "<strong id="modal-race-name"></strong>" khỏi hệ thống?</p>
        </div>
        <div style="padding:1rem 2rem 1.5rem; display:flex; justify-content:flex-end; gap:.75rem; border-top:1px solid #f1f5f9;">
            <button onclick="closeDeleteModal()" style="padding:9px 20px; border-radius:8px; border:1.5px solid #d1d5db; background:#fff; color:#374151; font-size:.875rem; font-weight:600; cursor:pointer;">✕ Hủy</button>
            <button onclick="confirmDelete()" style="padding:9px 20px; border-radius:8px; border:none; background:linear-gradient(135deg,#dc2626,#b91c1c); color:#fff; font-size:.875rem; font-weight:600; cursor:pointer;">🗑 Xác nhận xóa</button>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/signalr/dist/browser/signalr.min.js"></script>
<script src="~/lib/table-pagination/table-pagination.js"></script>
<script>
    "use strict";

    // Quyền của user hiện tại — dùng để dựng đúng nút Edit/Delete trên row mới do SignalR broadcast tới
    const canWrite = @Html.Raw(canWrite.ToString().ToLowerInvariant());
    const canDelete = @Html.Raw(canDelete.ToString().ToLowerInvariant());

    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/msRaceHub", { withCredentials: true })
        .build();

    var _pendingDeleteId = null;

    function openDeleteModal(btn) {
        _pendingDeleteId = btn.dataset.id;
        document.getElementById("modal-race-name").textContent = btn.dataset.raceName || "—";
        document.getElementById("deleteModal").style.display = "flex";
    }

    function closeDeleteModal() {
        document.getElementById("deleteModal").style.display = "none";
        _pendingDeleteId = null;
    }

    function confirmDelete() {
        if (!_pendingDeleteId) return;

        if (connection.state !== signalR.HubConnectionState.Connected) {
            showToast("Chưa kết nối được tới server, vui lòng thử lại sau giây lát.", "error");
            return;
        }

        connection.invoke("HubDelete_RegistrationNguyenDnt", parseInt(_pendingDeleteId))
            .catch(err => {
                console.error(err.toString());
                showToast("Không thể xóa qua SignalR: " + err.message, "error");
            });
        closeDeleteModal();
    }

    document.getElementById("deleteModal").addEventListener("click", function (e) {
        if (e.target === this) closeDeleteModal();
    });

    function updateTotalCount(delta) {
        var el = document.getElementById("rl-total-count");
        el.textContent = (parseInt(el.textContent) || 0) + delta;
    }

    function updateConfirmedCount(delta) {
        var el = document.getElementById("rl-confirmed-count");
        el.textContent = (parseInt(el.textContent) || 0) + delta;
    }

    function formatDate(value) {
        return value ? new Date(value).toLocaleDateString('vi-VN') : '—';
    }

    function formatPrize(value) {
        return value != null ? Number(value).toLocaleString('vi-VN') : '—';
    }

    function statusBadgeHtml(isConfirmed) {
        return isConfirmed
            ? '<span class="rl-badge-confirmed">● Đã xác nhận</span>'
            : '<span class="rl-badge-pending">● Chờ xác nhận</span>';
    }

    // Nhận broadcast xóa từ SignalR — xóa row khỏi DOM ở tất cả tab đang mở
    connection.on("Receiver_DeleteRegistrationNguyenDnt", function (id) {
        var row = document.getElementById(`registration-row-${id}`);
        if (!row) return;
        if (row.dataset.status === "confirmed") updateConfirmedCount(-1);
        row.remove();
        updateTotalCount(-1);
    });

    // Nhận broadcast tạo mới từ SignalR — chèn row mới lên đầu bảng ở tất cả tab đang mở
    connection.on("Receiver_CreateRegistrationNguyenDnt", function (item) {
        var tr = `
            <tr id="registration-row-${item.registrationNguyenDntid}" data-status="${item.isConfirmed ? 'confirmed' : 'pending'}">
                <td><span class="rl-race-code">#${item.registrationNguyenDntid}</span></td>
                <td>${item.raceName || ''}</td>
                <td>
                    <div class="rl-horse-cell">
                        <span class="rl-horse-avatar">🐎</span>
                        <span>${item.horseName || ''}</span>
                    </div>
                </td>
                <td>${formatDate(item.registeredDate)}</td>
                <td>${formatDate(item.responseDate)}</td>
                <td>${formatPrize(item.prizeMoney)}</td>
                <td>${statusBadgeHtml(item.isConfirmed)}</td>
                <td>${item.jockeyNguyenDntid ?? '—'}</td>
                <td>
                    <div class="rl-action-group">
                        ${canWrite ? `<a href="/RegistrationNguyenDnts/Edit/${item.registrationNguyenDntid}" class="rl-btn-action rl-btn-edit" title="Chỉnh sửa">✏️</a>` : ''}
                        <a href="/RegistrationNguyenDnts/Details/${item.registrationNguyenDntid}" class="rl-btn-action rl-btn-detail" title="Chi tiết">👁</a>
                        ${canDelete ? `<button class="rl-btn-action rl-btn-del" title="Xóa" onclick="openDeleteModal(this)" data-id="${item.registrationNguyenDntid}" data-race-name="${item.raceName || ''}">🗑</button>` : ''}
                    </div>
                </td>
            </tr>`;

        $('#registrationTableBody').prepend(tr);
        updateTotalCount(1);
        if (item.isConfirmed) updateConfirmedCount(1);
    });

    // Nhận broadcast sửa từ SignalR — cập nhật đúng row tại chỗ ở tất cả tab đang mở
    connection.on("Receiver_EditRegistrationNguyenDnt", function (item) {
        var row = document.getElementById(`registration-row-${item.registrationNguyenDntid}`);
        if (!row) return;

        var oldStatus = row.dataset.status;
        var newStatus = item.isConfirmed ? "confirmed" : "pending";
        if (oldStatus !== newStatus) {
            updateConfirmedCount(newStatus === "confirmed" ? 1 : -1);
        }
        row.dataset.status = newStatus;

        row.cells[1].textContent = item.raceName || '';
        row.cells[2].innerHTML = `<div class="rl-horse-cell"><span class="rl-horse-avatar">🐎</span><span>${item.horseName || ''}</span></div>`;
        row.cells[3].textContent = formatDate(item.registeredDate);
        row.cells[4].textContent = formatDate(item.responseDate);
        row.cells[5].textContent = formatPrize(item.prizeMoney);
        row.cells[6].innerHTML = statusBadgeHtml(item.isConfirmed);
        row.cells[7].textContent = item.jockeyNguyenDntid ?? '—';

        var deleteBtn = row.querySelector(".rl-btn-del");
        if (deleteBtn) deleteBtn.dataset.raceName = item.raceName || '';
    });

    connection.on("DeleteError", function (message) {
        const text = message && message.startsWith(":") ? message.slice(1) : message;
        showToast(text || "Xóa thất bại.", "error");
    });

    connection.start().catch(err => console.error(err.toString()));

    $(function () {
        $('#registrationTable').createTablePagination({
            rowPerPage: 5,
            paginationColor: '#7c3aed',
            fontColor: '#6b21a8',
            paginationStyle: 'bordered',
            jumpPage: true
        });
    });
</script>
}
