@model RaceMS.WebMVCApp.NguyenDNT.Models.RegisterRequest

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký - RaceMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600;700&display=swap');

        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(circle at 15% 20%, rgba(139,92,246,.25), transparent 40%),
                        radial-gradient(circle at 85% 80%, rgba(56,189,248,.18), transparent 45%),
                        linear-gradient(135deg, #1a1a2e 0%, #16213e 55%, #0f3460 100%);
            padding: 1.5rem;
        }

        .login-shell {
            width: 100%;
            max-width: 980px;
            display: grid;
            grid-template-columns: .85fr 1.15fr;
            background: rgba(255,255,255,.03);
            border: 1px solid rgba(255,255,255,.08);
            border-radius: 22px;
            overflow: hidden;
            box-shadow: 0 30px 80px rgba(0,0,0,.45);
            backdrop-filter: blur(6px);
        }

        /* ── LEFT: BRAND PANEL ── */
        .login-brand {
            position: relative;
            padding: 3rem 2.4rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            overflow: hidden;
            background: linear-gradient(160deg, rgba(124,58,237,.25), rgba(15,52,96,.1));
        }

        .login-brand::before {
            content: '';
            position: absolute;
            top: -70px; left: -60px;
            width: 220px; height: 220px;
            border-radius: 50%;
            background: rgba(139,92,246,.18);
        }

        .login-brand::after {
            content: '';
            position: absolute;
            bottom: -90px; right: -60px;
            width: 260px; height: 260px;
            border-radius: 50%;
            background: rgba(56,189,248,.12);
        }

        .brand-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            align-self: flex-start;
            background: rgba(139,92,246,.2);
            border: 1px solid rgba(139,92,246,.4);
            color: #c4b5fd;
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            padding: 5px 12px;
            border-radius: 20px;
            position: relative;
            z-index: 1;
        }

        .brand-title {
            position: relative;
            z-index: 1;
            margin-top: 1.4rem;
        }

        .brand-title h1 {
            font-family: 'Playfair Display', serif;
            color: #fff;
            font-size: 2.2rem;
            font-weight: 700;
            line-height: 1.15;
            margin: 0 0 .8rem;
        }

        .brand-title p {
            color: #a5b4d4;
            font-size: .9rem;
            line-height: 1.6;
            margin: 0;
            max-width: 300px;
        }

        /* ── RIGHT: FORM PANEL ── */
        .login-form-panel {
            background: #ffffff;
            padding: 2.6rem 2.6rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .login-form-panel h2 {
            font-size: 1.4rem;
            font-weight: 700;
            color: #1e1b4b;
            margin: 0 0 .3rem;
        }

        .login-form-panel .subtitle {
            color: #6b7280;
            font-size: .85rem;
            margin: 0 0 1.5rem;
        }

        .login-error-box {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 10px;
            padding: 10px 14px;
            margin-bottom: 1.3rem;
            color: #b91c1c;
            font-size: .82rem;
        }

        .login-error-box ul {
            margin: 0;
            padding-left: 1.1rem;
        }

        .login-error-box::before {
            content: '⚠️ Đăng ký thất bại';
            display: block;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .register-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0 1rem;
        }

        .register-grid .full-width { grid-column: 1 / -1; }

        .login-field { margin-bottom: 1rem; }

        .login-label {
            display: block;
            font-size: .8rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 6px;
        }

        .login-field-wrapper { position: relative; }

        .login-field-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            font-size: 1rem;
            pointer-events: none;
        }

        .login-input {
            width: 100%;
            padding: 10px 14px 10px 42px;
            border: 1.5px solid #d1d5db;
            border-radius: 10px;
            font-size: .88rem;
            font-family: 'Inter', sans-serif;
            color: #111827;
            background: #fafafa;
            box-sizing: border-box;
            transition: border-color .2s, box-shadow .2s, background .2s;
        }

        .login-input:focus {
            outline: none;
            border-color: #8b5cf6;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(139,92,246,.12);
        }

        .login-field-error {
            font-size: .73rem;
            color: #ef4444;
            margin-top: 4px;
            display: block;
        }

        .btn-login {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 10px;
            background: linear-gradient(135deg, #7c3aed, #6d28d9);
            color: #fff;
            font-size: .92rem;
            font-weight: 700;
            letter-spacing: .01em;
            cursor: pointer;
            box-shadow: 0 6px 18px rgba(109,40,217,.35);
            transition: all .2s;
            margin-top: .4rem;
        }

        .btn-login:hover {
            background: linear-gradient(135deg, #6d28d9, #5b21b6);
            transform: translateY(-1px);
            box-shadow: 0 8px 22px rgba(109,40,217,.45);
        }

        .btn-login:active { transform: translateY(0); }

        .switch-link {
            text-align: center;
            font-size: .82rem;
            color: #6b7280;
            margin-top: 1.2rem;
        }

        .switch-link a {
            color: #7c3aed;
            font-weight: 600;
            text-decoration: none;
        }

        .switch-link a:hover { text-decoration: underline; }

        @@media (max-width: 760px) {
            .login-shell { grid-template-columns: 1fr; }
            .login-brand { display: none; }
            .register-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <div class="login-shell">

        <!-- LEFT: BRAND -->
        <div class="login-brand">
            <div class="brand-badge">🏇 Race Management System</div>
            <div class="brand-title">
                <h1>Tạo tài khoản</h1>
                <p>Đăng ký để truy cập hệ thống quản lý jockey và đăng ký đua. Tài khoản mới mặc định ở quyền thấp nhất (chỉ xem) — liên hệ quản trị viên nếu cần nâng quyền.</p>
            </div>
        </div>

        <!-- RIGHT: FORM -->
        <div class="login-form-panel">
            <h2>Đăng ký tài khoản</h2>
            <p class="subtitle">Điền đầy đủ thông tin bên dưới</p>

            <div asp-validation-summary="ModelOnly" class="login-error-box text-danger" style="@(ViewData.ModelState.IsValid ? "display:none;" : "")"></div>

            <form asp-action="Register" method="post" novalidate>
                <div class="register-grid">
                    <div class="login-field full-width">
                        <label class="login-label" asp-for="FullName">Họ và tên</label>
                        <div class="login-field-wrapper">
                            <span class="login-field-icon">👤</span>
                            <input asp-for="FullName" class="login-input" placeholder="Nguyễn Văn A" autofocus />
                        </div>
                        <span asp-validation-for="FullName" class="login-field-error"></span>
                    </div>

                    <div class="login-field">
                        <label class="login-label" asp-for="Email">Email</label>
                        <div class="login-field-wrapper">
                            <span class="login-field-icon">✉️</span>
                            <input asp-for="Email" type="email" class="login-input" placeholder="ban@racems.vn" />
                        </div>
                        <span asp-validation-for="Email" class="login-field-error"></span>
                    </div>

                    <div class="login-field">
                        <label class="login-label" asp-for="Phone">Số điện thoại</label>
                        <div class="login-field-wrapper">
                            <span class="login-field-icon">📞</span>
                            <input asp-for="Phone" class="login-input" placeholder="0912 345 678" />
                        </div>
                        <span asp-validation-for="Phone" class="login-field-error"></span>
                    </div>

                    <div class="login-field">
                        <label class="login-label" asp-for="UserName">Tên đăng nhập</label>
                        <div class="login-field-wrapper">
                            <span class="login-field-icon">🆔</span>
                            <input asp-for="UserName" class="login-input" placeholder="Tên đăng nhập" autocomplete="username" />
                        </div>
                        <span asp-validation-for="UserName" class="login-field-error"></span>
                    </div>

                    <div class="login-field">
                        <label class="login-label" asp-for="EmployeeCode">Mã nhân viên</label>
                        <div class="login-field-wrapper">
                            <span class="login-field-icon">🏷️</span>
                            <input asp-for="EmployeeCode" class="login-input" placeholder="NV-0001" />
                        </div>
                        <span asp-validation-for="EmployeeCode" class="login-field-error"></span>
                    </div>

                    <div class="login-field">
                        <label class="login-label" asp-for="Password">Mật khẩu</label>
                        <div class="login-field-wrapper">
                            <span class="login-field-icon">🔒</span>
                            <input type="password" asp-for="Password" class="login-input" placeholder="Tối thiểu 6 ký tự" autocomplete="new-password" />
                        </div>
                        <span asp-validation-for="Password" class="login-field-error"></span>
                    </div>

                    <div class="login-field">
                        <label class="login-label" asp-for="ConfirmPassword">Xác nhận mật khẩu</label>
                        <div class="login-field-wrapper">
                            <span class="login-field-icon">🔒</span>
                            <input type="password" asp-for="ConfirmPassword" class="login-input" placeholder="Nhập lại mật khẩu" autocomplete="new-password" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="login-field-error"></span>
                    </div>
                </div>

                <button type="submit" class="btn-login">Đăng ký →</button>

                <div class="switch-link">
                    Đã có tài khoản? <a asp-action="Login">Đăng nhập ngay</a>
                </div>
            </form>
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
