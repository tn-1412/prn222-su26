@model RaceMS.WebMVCApp.NguyenDNT.Models.LoginRequest

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - RaceMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600;700&display=swap');

        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(circle at 15% 20%, rgba(139,92,246,.25), transparent 40%),
                        radial-gradient(circle at 85% 80%, rgba(56,189,248,.18), transparent 45%),
                        linear-gradient(135deg, #1a1a2e 0%, #16213e 55%, #0f3460 100%);
            padding: 1.5rem;
        }

        .login-shell {
            width: 100%;
            max-width: 900px;
            display: grid;
            grid-template-columns: 1.05fr 1fr;
            background: rgba(255,255,255,.03);
            border: 1px solid rgba(255,255,255,.08);
            border-radius: 22px;
            overflow: hidden;
            box-shadow: 0 30px 80px rgba(0,0,0,.45);
            backdrop-filter: blur(6px);
        }

        /* ── LEFT: BRAND PANEL ── */
        .login-brand {
            position: relative;
            padding: 3rem 2.6rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            overflow: hidden;
            background: linear-gradient(160deg, rgba(124,58,237,.25), rgba(15,52,96,.1));
        }

        .login-brand::before {
            content: '';
            position: absolute;
            top: -70px; left: -60px;
            width: 220px; height: 220px;
            border-radius: 50%;
            background: rgba(139,92,246,.18);
        }

        .login-brand::after {
            content: '';
            position: absolute;
            bottom: -90px; right: -60px;
            width: 260px; height: 260px;
            border-radius: 50%;
            background: rgba(56,189,248,.12);
        }

        .brand-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            align-self: flex-start;
            background: rgba(139,92,246,.2);
            border: 1px solid rgba(139,92,246,.4);
            color: #c4b5fd;
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            padding: 5px 12px;
            border-radius: 20px;
            position: relative;
            z-index: 1;
        }

        .brand-title {
            position: relative;
            z-index: 1;
            margin-top: 1.4rem;
        }

        .brand-title h1 {
            font-family: 'Playfair Display', serif;
            color: #fff;
            font-size: 2.4rem;
            font-weight: 700;
            line-height: 1.15;
            margin: 0 0 .8rem;
        }

        .brand-title p {
            color: #a5b4d4;
            font-size: .92rem;
            line-height: 1.6;
            margin: 0;
            max-width: 320px;
        }

        /* ── RIGHT: FORM PANEL ── */
        .login-form-panel {
            background: #ffffff;
            padding: 3rem 2.6rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .login-form-panel h2 {
            font-size: 1.4rem;
            font-weight: 700;
            color: #1e1b4b;
            margin: 0 0 .3rem;
        }

        .login-form-panel .subtitle {
            color: #6b7280;
            font-size: .85rem;
            margin: 0 0 1.8rem;
        }

        .login-error-box {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 10px;
            padding: 10px 14px;
            margin-bottom: 1.3rem;
            color: #b91c1c;
            font-size: .82rem;
        }

        .login-error-box ul {
            margin: 0;
            padding-left: 1.1rem;
        }

        .login-error-box::before {
            content: '⚠️ Đăng nhập thất bại';
            display: block;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .login-field { margin-bottom: 1.2rem; }

        .login-label {
            display: block;
            font-size: .8rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 6px;
        }

        .login-field-wrapper { position: relative; }

        .login-field-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            font-size: 1rem;
            pointer-events: none;
        }

        .login-input {
            width: 100%;
            padding: 11px 14px 11px 42px;
            border: 1.5px solid #d1d5db;
            border-radius: 10px;
            font-size: .9rem;
            font-family: 'Inter', sans-serif;
            color: #111827;
            background: #fafafa;
            box-sizing: border-box;
            transition: border-color .2s, box-shadow .2s, background .2s;
        }

        .login-input:focus {
            outline: none;
            border-color: #8b5cf6;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(139,92,246,.12);
        }

        .login-field-error {
            font-size: .75rem;
            color: #ef4444;
            margin-top: 4px;
            display: block;
        }

        .btn-login {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 10px;
            background: linear-gradient(135deg, #7c3aed, #6d28d9);
            color: #fff;
            font-size: .92rem;
            font-weight: 700;
            letter-spacing: .01em;
            cursor: pointer;
            box-shadow: 0 6px 18px rgba(109,40,217,.35);
            transition: all .2s;
            margin-top: .4rem;
        }

        .btn-login:hover {
            background: linear-gradient(135deg, #6d28d9, #5b21b6);
            transform: translateY(-1px);
            box-shadow: 0 8px 22px rgba(109,40,217,.45);
        }

        .btn-login:active { transform: translateY(0); }

        .login-success-box {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            border-radius: 10px;
            padding: 10px 14px;
            margin-bottom: 1.3rem;
            color: #15803d;
            font-size: .82rem;
        }

        .switch-link {
            text-align: center;
            font-size: .82rem;
            color: #6b7280;
            margin-top: 1.2rem;
        }

        .switch-link a {
            color: #7c3aed;
            font-weight: 600;
            text-decoration: none;
        }

        .switch-link a:hover { text-decoration: underline; }

        /* ── TOAST NOTIFICATION ── */
        .toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 10000;
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-width: 380px;
        }

        .toast {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 13px 16px;
            border-radius: 10px;
            font-family: 'Inter', sans-serif;
            font-size: .85rem;
            line-height: 1.45;
            box-shadow: 0 10px 30px rgba(0,0,0,.18);
            animation: toast-in .25s ease-out;
        }

        .toast-icon { font-size: 1rem; flex-shrink: 0; }
        .toast-message { flex: 1; word-break: break-word; }
        .toast-close { cursor: pointer; opacity: .55; font-size: .8rem; flex-shrink: 0; line-height: 1; }
        .toast-close:hover { opacity: 1; }
        .toast-error { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; }
        .toast-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #15803d; }

        @@keyframes toast-in {
            from { opacity: 0; transform: translateX(24px); }
            to { opacity: 1; transform: translateX(0); }
        }

        @@media (max-width: 760px) {
            .login-shell { grid-template-columns: 1fr; }
            .login-brand { display: none; }
        }
    </style>
</head>
<body>

    <div id="toastContainer" class="toast-container"></div>

    <div class="login-shell">

        <!-- LEFT: BRAND -->
        <div class="login-brand">
            <div class="brand-badge">🏇 Race Management System</div>
            <div class="brand-title">
                <h1>RaceMS</h1>
                <p>Quản lý jockey, đăng ký đua và cập nhật kết quả theo thời gian thực — tất cả trong một nền tảng duy nhất.</p>
            </div>
        </div>

        <!-- RIGHT: FORM -->
        <div class="login-form-panel">
            <h2>Đăng nhập</h2>
            <p class="subtitle">Nhập thông tin tài khoản để truy cập hệ thống</p>

            @if (TempData["RegisterSuccess"] != null)
            {
                <div class="login-success-box">✅ @TempData["RegisterSuccess"]</div>
            }

            <div asp-validation-summary="ModelOnly" class="login-error-box text-danger" style="@(ViewData.ModelState.IsValid ? "display:none;" : "")"></div>

            <form asp-action="Login" method="post" novalidate>
                <div class="login-field">
                    <label class="login-label" asp-for="UserName">Tên đăng nhập</label>
                    <div class="login-field-wrapper">
                        <span class="login-field-icon">👤</span>
                        <input asp-for="UserName" class="login-input" placeholder="Tên đăng nhập hoặc email" autocomplete="username" autofocus />
                    </div>
                    <span asp-validation-for="UserName" class="login-field-error"></span>
                </div>

                <div class="login-field">
                    <label class="login-label" asp-for="Password">Mật khẩu</label>
                    <div class="login-field-wrapper">
                        <span class="login-field-icon">🔒</span>
                        <input type="password" asp-for="Password" class="login-input" placeholder="••••••••" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="login-field-error"></span>
                </div>

                <button type="submit" class="btn-login">Đăng nhập →</button>

                <div class="switch-link">
                    Chưa có tài khoản? <a asp-action="Register">Đăng ký ngay</a>
                </div>
            </form>
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function showToast(message, type) {
            type = type === 'success' ? 'success' : 'error';
            var container = document.getElementById('toastContainer');
            if (!container || !message) return;

            var toast = document.createElement('div');
            toast.className = 'toast toast-' + type;
            toast.innerHTML =
                '<span class="toast-icon">' + (type === 'success' ? '✅' : '⚠️') + '</span>' +
                '<span class="toast-message"></span>' +
                '<span class="toast-close">✕</span>';
            toast.querySelector('.toast-message').textContent = message;
            toast.querySelector('.toast-close').addEventListener('click', function () { toast.remove(); });

            container.appendChild(toast);
            setTimeout(function () { toast.remove(); }, 6000);
        }
    </script>
    @if (!ViewData.ModelState.IsValid)
    {
        var firstError = ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage).FirstOrDefault(e => !string.IsNullOrWhiteSpace(e));
        if (!string.IsNullOrWhiteSpace(firstError))
        {
            <script>showToast(@Json.Serialize(firstError), 'error');</script>
        }
    }
    @if (TempData["RegisterSuccess"] != null)
    {
        <script>showToast(@Json.Serialize(TempData["RegisterSuccess"]), 'success');</script>
    }
</body>
</html>
