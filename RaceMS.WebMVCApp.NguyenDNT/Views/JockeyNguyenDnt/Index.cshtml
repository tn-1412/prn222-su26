@model IEnumerable<RaceMS.Entities.NguyenDNT.Models.JockeyNguyenDnt>

@{
    ViewData["Title"] = "Danh sách Jockey";
}

<h2 class="mb-4">Danh sách Jockey</h2>

<table class="table table-bordered table-hover table-striped">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Họ tên</th>
            <th>Số điện thoại</th>
            <th>Email</th>
            <th>Mã giấy phép</th>
            <th>Cân nặng (kg)</th>
            <th>Ngày sinh</th>
            <th>Trạng thái</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="8" class="text-center text-muted">Không có dữ liệu.</td>
            </tr>
        }
        else
        {
            int i = 1;
            foreach (var jockey in Model)
            {
                <tr>
                    <td>@(i++)</td>
                    <td>@jockey.FullName</td>
                    <td>@jockey.PhoneNumber</td>
                    <td>@jockey.Email</td>
                    <td>@jockey.LicenseCode</td>
                    <td>@(jockey.Weight.HasValue ? jockey.Weight.Value.ToString("F2") : "-")</td>
                    <td>@(jockey.DateOfBirth.HasValue ? jockey.DateOfBirth.Value.ToString("dd/MM/yyyy") : "-")</td>
                    <td>
                        @if (jockey.IsActive)
                        {
                            <span class="badge bg-success">Hoạt động</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Ngừng</span>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
