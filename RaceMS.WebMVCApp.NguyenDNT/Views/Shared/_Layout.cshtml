<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RaceMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RaceMS.WebMVCApp.NguyenDNT.styles.css" asp-append-version="true" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600;700&display=swap');

        body { font-family: 'Inter', sans-serif; }

        .app-navbar {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
            padding: .7rem 0;
            box-shadow: 0 4px 20px rgba(0,0,0,.15);
        }

        .app-navbar .navbar-brand {
            font-family: 'Playfair Display', serif;
            font-weight: 700;
            font-size: 1.35rem;
            color: #fff !important;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .app-navbar .navbar-toggler {
            border-color: rgba(255,255,255,.3);
        }

        .app-navbar .navbar-toggler-icon {
            filter: invert(1) grayscale(100%) brightness(200%);
        }

        .app-navbar .nav-link {
            color: rgba(255,255,255,.75) !important;
            font-weight: 500;
            font-size: .9rem;
            padding: 6px 14px !important;
            border-radius: 8px;
            transition: all .15s;
        }

        .app-navbar .nav-link:hover {
            color: #fff !important;
            background: rgba(139,92,246,.18);
        }

        .app-navbar .navbar-text-user {
            color: rgba(255,255,255,.65);
            font-size: .8rem;
        }

        .app-navbar .navbar-text-user strong {
            color: #fff;
        }

        .app-navbar .role-badge {
            display: inline-flex;
            align-items: center;
            background: rgba(139,92,246,.2);
            border: 1px solid rgba(139,92,246,.4);
            color: #c4b5fd;
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: .04em;
            text-transform: uppercase;
            padding: 2px 9px;
            border-radius: 20px;
            margin-left: 6px;
        }

        .app-navbar .btn-logout {
            border: 1.5px solid rgba(248,113,113,.5);
            color: #fca5a5;
            background: transparent;
            font-size: .82rem;
            font-weight: 600;
            padding: 5px 14px;
            border-radius: 8px;
            transition: all .15s;
        }

        .app-navbar .btn-logout:hover {
            background: #dc2626;
            border-color: #dc2626;
            color: #fff;
        }

        /* ── TOAST NOTIFICATION ── */
        /* Tiền tố "rms-" để KHÔNG trùng tên với component .toast có sẵn của Bootstrap
           (Bootstrap ẩn .toast mặc định bằng display:none, đè mất toast của mình nếu trùng tên). */
        .rms-toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 10000;
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-width: 380px;
        }

        .rms-toast {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 13px 16px;
            border-radius: 10px;
            font-family: 'Inter', sans-serif;
            font-size: .85rem;
            line-height: 1.45;
            box-shadow: 0 10px 30px rgba(0,0,0,.18);
            animation: rms-toast-in .25s ease-out;
        }

        .rms-toast-icon { font-size: 1rem; flex-shrink: 0; }
        .rms-toast-message { flex: 1; word-break: break-word; }

        .rms-toast-close {
            cursor: pointer;
            opacity: .55;
            font-size: .8rem;
            flex-shrink: 0;
            line-height: 1;
        }

        .rms-toast-close:hover { opacity: 1; }

        .rms-toast-error {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #b91c1c;
        }

        .rms-toast-success {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            color: #15803d;
        }

        @@keyframes rms-toast-in {
            from { opacity: 0; transform: translateX(24px); }
            to { opacity: 1; transform: translateX(0); }
        }
    </style>
</head>
<body>
    <div id="rmsToastContainer" class="rms-toast-container"></div>

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm app-navbar mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="JockeyNguyenDnts" asp-action="Index">
                    🏇 RaceMS
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="JockeyNguyenDnts" asp-action="Index">Jockeys</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="RegistrationNguyenDnts" asp-action="Index">Registrations</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Chat" asp-action="Index">💬 Chat</a>
                        </li>
                    </ul>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav ms-auto align-items-center">
                            <li class="nav-item me-3">
                                <span class="navbar-text-user">
                                    Xin chào, <strong>@(User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ?? User.Identity.Name)</strong>
                                    @{ var roleName = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value; }
                                    @if (!string.IsNullOrEmpty(roleName))
                                    {
                                        <span class="role-badge">@roleName</span>
                                    }
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-logout">Đăng xuất</button>
                                </form>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Popup thông báo nhỏ dùng chung toàn app — không chặn thao tác, tự biến mất sau vài giây.
        function showToast(message, type) {
            type = type === 'success' ? 'success' : 'error';
            var container = document.getElementById('rmsToastContainer');
            if (!container || !message) return;

            var toast = document.createElement('div');
            toast.className = 'rms-toast rms-toast-' + type;
            toast.innerHTML =
                '<span class="rms-toast-icon">' + (type === 'success' ? '✅' : '⚠️') + '</span>' +
                '<span class="rms-toast-message"></span>' +
                '<span class="rms-toast-close">✕</span>';
            toast.querySelector('.rms-toast-message').textContent = message;
            toast.querySelector('.rms-toast-close').addEventListener('click', function () { toast.remove(); });

            container.appendChild(toast);
            setTimeout(function () { toast.remove(); }, 6000);
        }
    </script>
    @{
        // Tự động hiện toast khi form submit thất bại validate (ModelState invalid) —
        // áp dụng cho MỌI trang dùng layout này (Jockey/Registration Create & Edit) mà không cần sửa từng view.
        if (!ViewData.ModelState.IsValid)
        {
            var firstError = ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage).FirstOrDefault(e => !string.IsNullOrWhiteSpace(e));
            if (!string.IsNullOrWhiteSpace(firstError))
            {
                <script>showToast(@Json.Serialize(firstError), 'error');</script>
            }
        }

        if (TempData.Peek("Error") != null)
        {
            <script>showToast(@Json.Serialize(TempData.Peek("Error")), 'error');</script>
        }
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
